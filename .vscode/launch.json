    "version": "0.2.0",
    "configurations": [
        {
            "type": "by-gdb",
            "request": "launch",
            "name": "Launch(remote)",
            "program": "Out/ch32v208_usb_mux_ble_host.elf",            
            "cwd": "${workspaceRoot}",
            "debuggerPath": "/opt/riscv-wch-toolchain/bin/riscv-none-embed-gdb",
            "stopAtEntry": true,
            "remote": {            
                "enabled": true,
                "address": ":3333",
                "mode": "remote",            
                "execfile": "Out/ch32v208_usb_mux_ble_host.elf"
            }
        }
    ]
}

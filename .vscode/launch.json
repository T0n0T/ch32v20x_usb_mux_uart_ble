    "version": "0.2.0",
    "configurations": [
        {
            "type": "by-gdb",
            "request": "launch",
            "name": "Debug with GDB Remote",
            "program": "Out/ch32v208_usb_mux_ble_host.elf",
            "cwd": "${workspaceRoot}",
            "debuggerPath": "gdb-multiarch",
            "remote": {
                "enabled": true,
                "address": ":3333",
                "mode": "remote",
                "execfile": "${fileBasenameNoExtension}"
            }
        },
        {
            "cwd": "${workspaceRoot}",
            "executable": "Out/ch32v208_usb_mux_ble_host.elf",
            "name": "Debug with OpenOCD",
            "request": "launch",
            "type": "cortex-debug",
            "gdbPath": "gdb-multiarch",
            "serverpath": "/opt/openocd-wch/bin/openocd",
            "servertype": "openocd",
            "svdPath": "Ld/CH32V208xx.svd",
            "configFiles": ["Scripts/openocd/ch32v208-wch-riscv.cfg"],
            "searchDir": [],
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none"
        }
    ]
}
